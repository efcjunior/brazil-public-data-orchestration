# Local host ports
AUTH_API_PORT=8080
BDI_API_PORT=8081
AUTH_MONGO_PORT=27018
BDI_MONGO_PORT=27019

# Published API images used by the default Docker Compose stack
AUTH_API_IMAGE=ghcr.io/efcjunior/auth-api:1.0.0
BDI_API_IMAGE=ghcr.io/efcjunior/bdi-api:1.0.1

# Auth service local bootstrap
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=local-admin-password

# JWT integration contract between auth-api and resource APIs
JWT_ISSUER=http://auth-api:8080
JWT_ALLOWED_AUDIENCES=bdi-api,another-api
AUTH_JWT_AUDIENCE=bdi-api

# Rate-limit proxy behavior for local development
AUTH_API_RATE_LIMIT_TRUST_FORWARDED_HEADERS=false
BDI_API_RATE_LIMIT_TRUST_FORWARDED_HEADERS=false

LOGGING_STRUCTURED_FORMAT_CONSOLE=logstash
